<scene version="2.0.0">
    <integrator type="aov">
            <string name="aovs" value="depth:depth,normal:sh_normal"/>
            <integrator type="stokes" name="stokes">
                <!-- <integrator type="path">
                    <integer name="max_depth" value="-1" />
                    <integer name="rr_depth" value="5" />
                    <boolean name="hide_emitters" value="false" />
                </integrator> -->
                <integrator type="direct">
                    <integer name="shading_samples" value="10" />
                </integrator>
            </integrator>
    </integrator>
    
    <sensor type="perspective">
        <float name="near_clip" value="1" />
        <float name="far_clip" value="1000" />
        <string name="focal_length" value="35mm" />
        <transform name="to_world">
            <lookat target="0.0, 0.0, 0.0" 
                    origin="0.0, 10.0, 0.0" 
                    up="0.0, 0.0, 1.0" />
        </transform>
        <film type="hdrfilm">
            <rfilter type="gaussian" />
            <integer name="width" value="1080" />
            <integer name="height" value="1080" />
        </film>
        <sampler type="stratified">
            <integer name="sample_count" value="36" />
        </sampler>
    </sensor>
    <shape type="sphere">
        <point name="center" x="0" y="0" z="0" />
        <float name="radius" value="2"/>
        <bsdf type="pplastic">
            <rgb name="diffuse_reflectance" value="0.5"/>
            <rgb name="specular_reflectance" value="1"/>
            <float name="alpha" value="0.01" />
            <float name="int_ior" value="1.5" />
            <float name="ext_ior" value="1.0" />
            <string name="distribution" value="ggx" />
        </bsdf>
        <medium type="homogeneous" name="interior">
            <!-- <float name="scale" value="4"/> -->
            <!-- <rgb name="reflectance" value="0.3, 0.5, 0.7"/> -->
            <rgb name="albedo" value="1, 1, 1"/>
        </medium>
        <!-- <transform name="to_world">
            <rotate x="0.0" y="1.0" z="1.0" angle="15" />
            <rotate x="0.0" y="0.0" z="1.0" angle="-15" />
            <translate y="15.0" z="-1.0" />
        </transform> -->
    </shape>
    <emitter type="directional">
        <transform name="to_world">
            <lookat target="0.0, 0.0, 0.0" 
                    origin="5.0, 0.0, 0.0" 
                    up="0.0, 0.0, 1.0" />
        </transform>
        <rgb name="irradiance" value="0.2"/>
    </emitter>
    <!-- <emitter type="envmap">
        <string name="filename" value="envmap/Ueno-Shrine/03-Ueno-Shrine_Env.hdr" />
        <transform name="to_world">
            <scale value="1"/>
            <rotate x="0.0" y="0.0" z="1.0" angle="40" />
        </transform>
    </emitter> -->
</scene>
