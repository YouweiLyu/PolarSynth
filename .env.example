# Copy this file to `.env` and adjust paths to point at your asset / dataset
# storage. The pipeline reads these via utils/paths.py; CLI flags still win
# over env vars where both are provided.

# --- Input assets ----------------------------------------------------------

# Root of the pre-acquired 3D asset collection. The pipeline expects
# subdirectories `hdri/`, `materials/`, and `models/` under this path.
MITSUBA_ASSETS_DIR=./assets/3D_assets

# Override individual subroots if your layout differs:
# MITSUBA_HDRI_DIR=/data/polyhaven_hdris
# MITSUBA_MATERIALS_DIR=/data/ambientcg_materials
# MITSUBA_MODELS_DIR=/data/3d_models

# Fallback texture/HDRI used when a sampled material is missing files.
# MITSUBA_DEFAULT_MATERIAL=./assets/3D_assets/materials/ambientcg/Candy/Candy001
# MITSUBA_DEFAULT_HDRI=./assets/3D_assets/hdri/polyhaven/spiaggia_di_mondello_2k.exr

# --- Generated datasets ----------------------------------------------------

# Root of rendered output collections (used by check_scripts/* and run/*.sh).
MITSUBA_DATA_DIR=./datasets

# --- Logging ---------------------------------------------------------------

# DEBUG / INFO / WARNING / ERROR. Default INFO. Pass --debug on CLI to force DEBUG.
# MITSUBA_RENDER_LOG_LEVEL=INFO

# --- Mitsuba variant -------------------------------------------------------

# Used by run/*.sh and as the default for --mi_variant. One of:
#   scalar_rgb, scalar_spectral_polarized,
#   llvm_spectral_polarized, cuda_spectral_polarized
# MI_DEFAULT_VARIANT=llvm_spectral_polarized
